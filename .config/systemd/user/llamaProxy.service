[Unit]
Description=llama.cpp token-budgeting proxy
After=llamaServer.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /home/max/Projects/turboquant-llama/llamaProxy.py
Restart=always
RestartSec=5
StandardOutput=append:%h/.cache/llamaProxy.log
StandardError=append:%h/.cache/llamaProxy.log

[Install]
WantedBy=default.target
