# Auto-generated from pywal by updateYaziTheme.sh
# Source: /home/max/.cache/wal/colors.env
#
# This file intentionally overrides only a handful of high-impact UI styles.
# Anything not specified here falls back to Yazi's preset theme.

[app]
# Requires OSC 11 support (kitty supports it).
overall = { bg = "#161717" }

[mgr]
# CWD/header
cwd = { fg = "#54879c", bold = true }

# Markers
marker_selected = { fg = "#54879c", bold = true }
marker_marked   = { fg = "#93b2c5", bold = true }
marker_copied   = { fg = "#36665b", bold = true }
marker_cut      = { fg = "#365964", bold = true }

# Counts
count_selected = { fg = "#54879c", bold = true }
count_copied   = { fg = "#36665b" }
count_cut      = { fg = "#365964" }

# Pane borders
border_symbol = "│"
border_style  = { fg = "#505151" }

[indicator]
parent  = { fg = "#505151" }
current = { fg = "#54879c" }
preview = { fg = "#93b2c5" }

[tabs]
active   = { fg = "#161717", bg = "#54879c", bold = true }
inactive = { fg = "#c4c5c5", bg = "#161717" }
sep_inner = { open = "[", close = "]" }
sep_outer = { open = "", close = "" }

[mode]
normal_main = { fg = "#161717", bg = "#54879c", bold = true }
normal_alt  = { fg = "#c4c5c5", bg = "#161717" }
select_main = { fg = "#161717", bg = "#36665b", bold = true }
select_alt  = { fg = "#c4c5c5", bg = "#161717" }
unset_main  = { fg = "#161717", bg = "#3c6570", bold = true }
unset_alt   = { fg = "#c4c5c5", bg = "#161717" }

[status]
overall         = { fg = "#c4c5c5", bg = "#161717" }
progress_label  = { fg = "#54879c", bold = true }
progress_normal = { fg = "#161717", bg = "#54879c" }
progress_error  = { fg = "#161717", bg = "#365964" }
perm_type  = { fg = "#93b2c5" }
perm_read  = { fg = "#36665b" }
perm_write = { fg = "#3c6570" }
perm_exec  = { fg = "#365964" }
perm_sep   = { fg = "#505151" }

[notify]
title_info  = { fg = "#54879c", bold = true }
title_warn  = { fg = "#3c6570", bold = true }
title_error = { fg = "#365964", bold = true }

[pick]
border   = { fg = "#505151" }
active   = { fg = "#161717", bg = "#54879c" }
inactive = { fg = "#c4c5c5", bg = "#161717" }

[input]
border   = { fg = "#505151" }
title    = { fg = "#54879c", bold = true }
value    = { fg = "#c4c5c5" }
selected = { fg = "#161717", bg = "#54879c" }

[cmp]
border   = { fg = "#505151" }
active   = { fg = "#161717", bg = "#54879c" }
inactive = { fg = "#c4c5c5", bg = "#161717" }

[tasks]
border  = { fg = "#505151" }
title   = { fg = "#54879c", bold = true }
hovered = { fg = "#161717", bg = "#54879c" }

[help]
on      = { fg = "#54879c", bold = true }
run     = { fg = "#c4c5c5" }
desc    = { fg = "#505151" }
hovered = { fg = "#161717", bg = "#54879c" }
footer  = { fg = "#505151" }

[filetype]
# A small set of readable defaults that won't depend on terminal palette.
rules = [
  { mime = "image/*",            fg = "#3c6570" },
  { mime = "{audio,video}/*",    fg = "#86a9bd" },
  { mime = "inode/empty",        fg = "#93b2c5" },
  { url  = "*", is = "orphan",   fg = "#365964", bold = true },
  { url  = "*/",                fg = "#54879c", bold = true },
]
