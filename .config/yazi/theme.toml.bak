# Auto-generated from pywal by updateYaziTheme.sh
# Source: /home/max/.cache/wal/colors.env
#
# This file intentionally overrides only a handful of high-impact UI styles.
# Anything not specified here falls back to Yazi's preset theme.

[app]
# Requires OSC 11 support (kitty supports it).
overall = { bg = "#091914" }

[mgr]
# CWD/header
cwd = { fg = "#2c4552", bold = true }

# Markers
marker_selected = { fg = "#2c4552", bold = true }
marker_marked   = { fg = "#5ca794", bold = true }
marker_copied   = { fg = "#51322b", bold = true }
marker_cut      = { fg = "#1a2931", bold = true }

# Counts
count_selected = { fg = "#2c4552", bold = true }
count_copied   = { fg = "#51322b" }
count_cut      = { fg = "#1a2931" }

# Pane borders
border_symbol = "│"
border_style  = { fg = "#4f3f3b" }

[indicator]
parent  = { fg = "#4f3f3b" }
current = { fg = "#2c4552" }
preview = { fg = "#5ca794" }

[tabs]
active   = { fg = "#091914", bg = "#2c4552", bold = true }
inactive = { fg = "#a79f9d", bg = "#253c35" }
sep_inner = { open = "[", close = "]" }
sep_outer = { open = "", close = "" }

[mode]
normal_main = { fg = "#091914", bg = "#2c4552", bold = true }
normal_alt  = { fg = "#a79f9d", bg = "#253c35" }
select_main = { fg = "#091914", bg = "#51322b", bold = true }
select_alt  = { fg = "#a79f9d", bg = "#253c35" }
unset_main  = { fg = "#091914", bg = "#243b43", bold = true }
unset_alt   = { fg = "#a79f9d", bg = "#253c35" }

[status]
overall         = { fg = "#a79f9d", bg = "#253c35" }
progress_label  = { fg = "#2c4552", bold = true }
progress_normal = { fg = "#070202", bg = "#2c4552" }
progress_error  = { fg = "#070202", bg = "#1a2931" }
perm_type  = { fg = "#5ca794" }
perm_read  = { fg = "#51322b" }
perm_write = { fg = "#243b43" }
perm_exec  = { fg = "#1a2931" }
perm_sep   = { fg = "#4f3f3b" }

[notify]
title_info  = { fg = "#2c4552", bold = true }
title_warn  = { fg = "#243b43", bold = true }
title_error = { fg = "#1a2931", bold = true }

[pick]
border   = { fg = "#4f3f3b" }
active   = { fg = "#091914", bg = "#2c4552" }
inactive = { fg = "#a79f9d", bg = "#253c35" }

[input]
border   = { fg = "#4f3f3b" }
title    = { fg = "#2c4552", bold = true }
value    = { fg = "#a79f9d" }
selected = { fg = "#070202", bg = "#2c4552" }

[cmp]
border   = { fg = "#4f3f3b" }
active   = { fg = "#091914", bg = "#2c4552" }
inactive = { fg = "#a79f9d", bg = "#253c35" }

[tasks]
border  = { fg = "#4f3f3b" }
title   = { fg = "#2c4552", bold = true }
hovered = { fg = "#070202", bg = "#2c4552" }

[help]
on      = { fg = "#2c4552", bold = true }
run     = { fg = "#a79f9d" }
desc    = { fg = "#4f3f3b" }
hovered = { fg = "#070202", bg = "#2c4552" }
footer  = { fg = "#4f3f3b" }

[filetype]
# A small set of readable defaults that won't depend on terminal palette.
rules = [
  { mime = "image/*",            fg = "#243b43" },
  { mime = "{audio,video}/*",    fg = "#875848" },
  { mime = "inode/empty",        fg = "#5ca794" },
  { url  = "*", is = "orphan",   fg = "#1a2931", bold = true },
  { url  = "*/",                fg = "#2c4552", bold = true },
]
