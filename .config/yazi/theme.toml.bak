# Auto-generated from pywal by updateYaziTheme.sh
# Source: /home/max/.cache/wal/colors.env
#
# This file intentionally overrides only a handful of high-impact UI styles.
# Anything not specified here falls back to Yazi's preset theme.

[app]
# Requires OSC 11 support (kitty supports it).
overall = { bg = "#251d10" }

[mgr]
# CWD/header
cwd = { fg = "#589ca3", bold = true }

# Markers
marker_selected = { fg = "#589ca3", bold = true }
marker_marked   = { fg = "#a5586b", bold = true }
marker_copied   = { fg = "#9ecbad", bold = true }
marker_cut      = { fg = "#ab9164", bold = true }

# Counts
count_selected = { fg = "#589ca3", bold = true }
count_copied   = { fg = "#9ecbad" }
count_cut      = { fg = "#ab9164" }

# Pane borders
border_symbol = "│"
border_style  = { fg = "#5b554b" }

[indicator]
parent  = { fg = "#5b554b" }
current = { fg = "#589ca3" }
preview = { fg = "#a5586b" }

[tabs]
active   = { fg = "#251d10", bg = "#589ca3", bold = true }
inactive = { fg = "#c8c6c3", bg = "#251d10" }
sep_inner = { open = "[", close = "]" }
sep_outer = { open = "", close = "" }

[mode]
normal_main = { fg = "#251d10", bg = "#589ca3", bold = true }
normal_alt  = { fg = "#c8c6c3", bg = "#251d10" }
select_main = { fg = "#251d10", bg = "#9ecbad", bold = true }
select_alt  = { fg = "#c8c6c3", bg = "#251d10" }
unset_main  = { fg = "#251d10", bg = "#77b6ac", bold = true }
unset_alt   = { fg = "#c8c6c3", bg = "#251d10" }

[status]
overall         = { fg = "#c8c6c3", bg = "#251d10" }
progress_label  = { fg = "#589ca3", bold = true }
progress_normal = { fg = "#251d10", bg = "#589ca3" }
progress_error  = { fg = "#251d10", bg = "#ab9164" }
perm_type  = { fg = "#a5586b" }
perm_read  = { fg = "#9ecbad" }
perm_write = { fg = "#77b6ac" }
perm_exec  = { fg = "#ab9164" }
perm_sep   = { fg = "#5b554b" }

[notify]
title_info  = { fg = "#589ca3", bold = true }
title_warn  = { fg = "#77b6ac", bold = true }
title_error = { fg = "#ab9164", bold = true }

[pick]
border   = { fg = "#5b554b" }
active   = { fg = "#251d10", bg = "#589ca3" }
inactive = { fg = "#c8c6c3", bg = "#251d10" }

[input]
border   = { fg = "#5b554b" }
title    = { fg = "#589ca3", bold = true }
value    = { fg = "#c8c6c3" }
selected = { fg = "#251d10", bg = "#589ca3" }

[cmp]
border   = { fg = "#5b554b" }
active   = { fg = "#251d10", bg = "#589ca3" }
inactive = { fg = "#c8c6c3", bg = "#251d10" }

[tasks]
border  = { fg = "#5b554b" }
title   = { fg = "#589ca3", bold = true }
hovered = { fg = "#251d10", bg = "#589ca3" }

[help]
on      = { fg = "#589ca3", bold = true }
run     = { fg = "#c8c6c3" }
desc    = { fg = "#5b554b" }
hovered = { fg = "#251d10", bg = "#589ca3" }
footer  = { fg = "#5b554b" }

[filetype]
# A small set of readable defaults that won't depend on terminal palette.
rules = [
  { mime = "image/*",            fg = "#77b6ac" },
  { mime = "{audio,video}/*",    fg = "#b575b5" },
  { mime = "inode/empty",        fg = "#a5586b" },
  { url  = "*", is = "orphan",   fg = "#ab9164", bold = true },
  { url  = "*/",                fg = "#589ca3", bold = true },
]
