# Auto-generated from pywal by updateYaziTheme.sh
# Source: /home/max/.cache/wal/colors.env
#
# This file intentionally overrides only a handful of high-impact UI styles.
# Anything not specified here falls back to Yazi's preset theme.

[app]
# Requires OSC 11 support (kitty supports it).
overall = { bg = "#191a19" }

[mgr]
# CWD/header
cwd = { fg = "#6d5b3b", bold = true }

# Markers
marker_selected = { fg = "#6d5b3b", bold = true }
marker_marked   = { fg = "#b28370", bold = true }
marker_copied   = { fg = "#305a37", bold = true }
marker_cut      = { fg = "#663f37", bold = true }

# Counts
count_selected = { fg = "#6d5b3b", bold = true }
count_copied   = { fg = "#305a37" }
count_cut      = { fg = "#663f37" }

# Pane borders
border_symbol = "│"
border_style  = { fg = "#525352" }

[indicator]
parent  = { fg = "#525352" }
current = { fg = "#6d5b3b" }
preview = { fg = "#b28370" }

[tabs]
active   = { fg = "#191a19", bg = "#6d5b3b", bold = true }
inactive = { fg = "#c5c5c5", bg = "#191a19" }
sep_inner = { open = "[", close = "]" }
sep_outer = { open = "", close = "" }

[mode]
normal_main = { fg = "#191a19", bg = "#6d5b3b", bold = true }
normal_alt  = { fg = "#c5c5c5", bg = "#191a19" }
select_main = { fg = "#191a19", bg = "#305a37", bold = true }
select_alt  = { fg = "#c5c5c5", bg = "#191a19" }
unset_main  = { fg = "#191a19", bg = "#2c524c", bold = true }
unset_alt   = { fg = "#c5c5c5", bg = "#191a19" }

[status]
overall         = { fg = "#c5c5c5", bg = "#191a19" }
progress_label  = { fg = "#6d5b3b", bold = true }
progress_normal = { fg = "#191a19", bg = "#6d5b3b" }
progress_error  = { fg = "#191a19", bg = "#663f37" }
perm_type  = { fg = "#b28370" }
perm_read  = { fg = "#305a37" }
perm_write = { fg = "#2c524c" }
perm_exec  = { fg = "#663f37" }
perm_sep   = { fg = "#525352" }

[notify]
title_info  = { fg = "#6d5b3b", bold = true }
title_warn  = { fg = "#2c524c", bold = true }
title_error = { fg = "#663f37", bold = true }

[pick]
border   = { fg = "#525352" }
active   = { fg = "#191a19", bg = "#6d5b3b" }
inactive = { fg = "#c5c5c5", bg = "#191a19" }

[input]
border   = { fg = "#525352" }
title    = { fg = "#6d5b3b", bold = true }
value    = { fg = "#c5c5c5" }
selected = { fg = "#191a19", bg = "#6d5b3b" }

[cmp]
border   = { fg = "#525352" }
active   = { fg = "#191a19", bg = "#6d5b3b" }
inactive = { fg = "#c5c5c5", bg = "#191a19" }

[tasks]
border  = { fg = "#525352" }
title   = { fg = "#6d5b3b", bold = true }
hovered = { fg = "#191a19", bg = "#6d5b3b" }

[help]
on      = { fg = "#6d5b3b", bold = true }
run     = { fg = "#c5c5c5" }
desc    = { fg = "#525352" }
hovered = { fg = "#191a19", bg = "#6d5b3b" }
footer  = { fg = "#525352" }

[filetype]
# A small set of readable defaults that won't depend on terminal palette.
rules = [
  { mime = "image/*",            fg = "#2c524c" },
  { mime = "{audio,video}/*",    fg = "#897749" },
  { mime = "inode/empty",        fg = "#b28370" },
  { url  = "*", is = "orphan",   fg = "#663f37", bold = true },
  { url  = "*/",                fg = "#6d5b3b", bold = true },
]
