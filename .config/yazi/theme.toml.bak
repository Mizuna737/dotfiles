# Auto-generated from pywal by updateYaziTheme.sh
# Source: /home/max/.cache/wal/colors.env
#
# This file intentionally overrides only a handful of high-impact UI styles.
# Anything not specified here falls back to Yazi's preset theme.

[app]
# Requires OSC 11 support (kitty supports it).
overall = { bg = "#011932" }

[mgr]
# CWD/header
cwd = { fg = "#a55965", bold = true }

# Markers
marker_selected = { fg = "#a55965", bold = true }
marker_marked   = { fg = "#3c5571", bold = true }
marker_copied   = { fg = "#7a4158", bold = true }
marker_cut      = { fg = "#6d4178", bold = true }

# Counts
count_selected = { fg = "#a55965", bold = true }
count_copied   = { fg = "#7a4158" }
count_cut      = { fg = "#6d4178" }

# Pane borders
border_symbol = "│"
border_style  = { fg = "#6d728d" }

[indicator]
parent  = { fg = "#6d728d" }
current = { fg = "#a55965" }
preview = { fg = "#3c5571" }

[tabs]
active   = { fg = "#011932", bg = "#a55965", bold = true }
inactive = { fg = "#9da4ca", bg = "#011932" }
sep_inner = { open = "[", close = "]" }
sep_outer = { open = "", close = "" }

[mode]
normal_main = { fg = "#011932", bg = "#a55965", bold = true }
normal_alt  = { fg = "#9da4ca", bg = "#011932" }
select_main = { fg = "#011932", bg = "#7a4158", bold = true }
select_alt  = { fg = "#9da4ca", bg = "#011932" }
unset_main  = { fg = "#011932", bg = "#8f4d5f", bold = true }
unset_alt   = { fg = "#9da4ca", bg = "#011932" }

[status]
overall         = { fg = "#9da4ca", bg = "#011932" }
progress_label  = { fg = "#a55965", bold = true }
progress_normal = { fg = "#011932", bg = "#a55965" }
progress_error  = { fg = "#011932", bg = "#6d4178" }
perm_type  = { fg = "#3c5571" }
perm_read  = { fg = "#7a4158" }
perm_write = { fg = "#8f4d5f" }
perm_exec  = { fg = "#6d4178" }
perm_sep   = { fg = "#6d728d" }

[notify]
title_info  = { fg = "#a55965", bold = true }
title_warn  = { fg = "#8f4d5f", bold = true }
title_error = { fg = "#6d4178", bold = true }

[pick]
border   = { fg = "#6d728d" }
active   = { fg = "#011932", bg = "#a55965" }
inactive = { fg = "#9da4ca", bg = "#011932" }

[input]
border   = { fg = "#6d728d" }
title    = { fg = "#a55965", bold = true }
value    = { fg = "#9da4ca" }
selected = { fg = "#011932", bg = "#a55965" }

[cmp]
border   = { fg = "#6d728d" }
active   = { fg = "#011932", bg = "#a55965" }
inactive = { fg = "#9da4ca", bg = "#011932" }

[tasks]
border  = { fg = "#6d728d" }
title   = { fg = "#a55965", bold = true }
hovered = { fg = "#011932", bg = "#a55965" }

[help]
on      = { fg = "#a55965", bold = true }
run     = { fg = "#9da4ca" }
desc    = { fg = "#6d728d" }
hovered = { fg = "#011932", bg = "#a55965" }
footer  = { fg = "#6d728d" }

[filetype]
# A small set of readable defaults that won't depend on terminal palette.
rules = [
  { mime = "image/*",            fg = "#8f4d5f" },
  { mime = "{audio,video}/*",    fg = "#30415b" },
  { mime = "inode/empty",        fg = "#3c5571" },
  { url  = "*", is = "orphan",   fg = "#6d4178", bold = true },
  { url  = "*/",                fg = "#a55965", bold = true },
]
