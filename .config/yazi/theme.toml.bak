# Auto-generated from pywal by updateYaziTheme.sh
# Source: /home/max/.cache/wal/colors.env
#
# This file intentionally overrides only a handful of high-impact UI styles.
# Anything not specified here falls back to Yazi's preset theme.

[app]
# Requires OSC 11 support (kitty supports it).
overall = { bg = "#121d21" }

[mgr]
# CWD/header
cwd = { fg = "#6a57a3", bold = true }

# Markers
marker_selected = { fg = "#6a57a3", bold = true }
marker_marked   = { fg = "#955061", bold = true }
marker_copied   = { fg = "#4e6490", bold = true }
marker_cut      = { fg = "#5d93a7", bold = true }

# Counts
count_selected = { fg = "#6a57a3", bold = true }
count_copied   = { fg = "#4e6490" }
count_cut      = { fg = "#5d93a7" }

# Pane borders
border_symbol = "│"
border_style  = { fg = "#4d5558" }

[indicator]
parent  = { fg = "#4d5558" }
current = { fg = "#6a57a3" }
preview = { fg = "#955061" }

[tabs]
active   = { fg = "#121d21", bg = "#6a57a3", bold = true }
inactive = { fg = "#c3c6c7", bg = "#121d21" }
sep_inner = { open = "[", close = "]" }
sep_outer = { open = "", close = "" }

[mode]
normal_main = { fg = "#121d21", bg = "#6a57a3", bold = true }
normal_alt  = { fg = "#c3c6c7", bg = "#121d21" }
select_main = { fg = "#121d21", bg = "#4e6490", bold = true }
select_alt  = { fg = "#c3c6c7", bg = "#121d21" }
unset_main  = { fg = "#121d21", bg = "#4e4c8f", bold = true }
unset_alt   = { fg = "#c3c6c7", bg = "#121d21" }

[status]
overall         = { fg = "#c3c6c7", bg = "#121d21" }
progress_label  = { fg = "#6a57a3", bold = true }
progress_normal = { fg = "#121d21", bg = "#6a57a3" }
progress_error  = { fg = "#121d21", bg = "#5d93a7" }
perm_type  = { fg = "#955061" }
perm_read  = { fg = "#4e6490" }
perm_write = { fg = "#4e4c8f" }
perm_exec  = { fg = "#5d93a7" }
perm_sep   = { fg = "#4d5558" }

[notify]
title_info  = { fg = "#6a57a3", bold = true }
title_warn  = { fg = "#4e4c8f", bold = true }
title_error = { fg = "#5d93a7", bold = true }

[pick]
border   = { fg = "#4d5558" }
active   = { fg = "#121d21", bg = "#6a57a3" }
inactive = { fg = "#c3c6c7", bg = "#121d21" }

[input]
border   = { fg = "#4d5558" }
title    = { fg = "#6a57a3", bold = true }
value    = { fg = "#c3c6c7" }
selected = { fg = "#121d21", bg = "#6a57a3" }

[cmp]
border   = { fg = "#4d5558" }
active   = { fg = "#121d21", bg = "#6a57a3" }
inactive = { fg = "#c3c6c7", bg = "#121d21" }

[tasks]
border  = { fg = "#4d5558" }
title   = { fg = "#6a57a3", bold = true }
hovered = { fg = "#121d21", bg = "#6a57a3" }

[help]
on      = { fg = "#6a57a3", bold = true }
run     = { fg = "#c3c6c7" }
desc    = { fg = "#4d5558" }
hovered = { fg = "#121d21", bg = "#6a57a3" }
footer  = { fg = "#4d5558" }

[filetype]
# A small set of readable defaults that won't depend on terminal palette.
rules = [
  { mime = "image/*",            fg = "#4e4c8f" },
  { mime = "{audio,video}/*",    fg = "#b3739f" },
  { mime = "inode/empty",        fg = "#955061" },
  { url  = "*", is = "orphan",   fg = "#5d93a7", bold = true },
  { url  = "*/",                fg = "#6a57a3", bold = true },
]
