# Auto-generated from pywal by updateYaziTheme.sh
# Source: /home/max/.cache/wal/colors.env
#
# This file intentionally overrides only a handful of high-impact UI styles.
# Anything not specified here falls back to Yazi's preset theme.

[app]
# Requires OSC 11 support (kitty supports it).
overall = { bg = "#211d1c" }

[mgr]
# CWD/header
cwd = { fg = "#6b84af", bold = true }

# Markers
marker_selected = { fg = "#6b84af", bold = true }
marker_marked   = { fg = "#868abd", bold = true }
marker_copied   = { fg = "#d0c0a7", bold = true }
marker_cut      = { fg = "#b98a7d", bold = true }

# Counts
count_selected = { fg = "#6b84af", bold = true }
count_copied   = { fg = "#d0c0a7" }
count_cut      = { fg = "#b98a7d" }

# Pane borders
border_symbol = "│"
border_style  = { fg = "#585554" }

[indicator]
parent  = { fg = "#585554" }
current = { fg = "#6b84af" }
preview = { fg = "#868abd" }

[tabs]
active   = { fg = "#211d1c", bg = "#6b84af", bold = true }
inactive = { fg = "#c7c6c6", bg = "#211d1c" }
sep_inner = { open = "[", close = "]" }
sep_outer = { open = "", close = "" }

[mode]
normal_main = { fg = "#211d1c", bg = "#6b84af", bold = true }
normal_alt  = { fg = "#c7c6c6", bg = "#211d1c" }
select_main = { fg = "#211d1c", bg = "#d0c0a7", bold = true }
select_alt  = { fg = "#c7c6c6", bg = "#211d1c" }
unset_main  = { fg = "#211d1c", bg = "#54729c", bold = true }
unset_alt   = { fg = "#c7c6c6", bg = "#211d1c" }

[status]
overall         = { fg = "#c7c6c6", bg = "#211d1c" }
progress_label  = { fg = "#6b84af", bold = true }
progress_normal = { fg = "#211d1c", bg = "#6b84af" }
progress_error  = { fg = "#211d1c", bg = "#b98a7d" }
perm_type  = { fg = "#868abd" }
perm_read  = { fg = "#d0c0a7" }
perm_write = { fg = "#54729c" }
perm_exec  = { fg = "#b98a7d" }
perm_sep   = { fg = "#585554" }

[notify]
title_info  = { fg = "#6b84af", bold = true }
title_warn  = { fg = "#54729c", bold = true }
title_error = { fg = "#b98a7d", bold = true }

[pick]
border   = { fg = "#585554" }
active   = { fg = "#211d1c", bg = "#6b84af" }
inactive = { fg = "#c7c6c6", bg = "#211d1c" }

[input]
border   = { fg = "#585554" }
title    = { fg = "#6b84af", bold = true }
value    = { fg = "#c7c6c6" }
selected = { fg = "#211d1c", bg = "#6b84af" }

[cmp]
border   = { fg = "#585554" }
active   = { fg = "#211d1c", bg = "#6b84af" }
inactive = { fg = "#c7c6c6", bg = "#211d1c" }

[tasks]
border  = { fg = "#585554" }
title   = { fg = "#6b84af", bold = true }
hovered = { fg = "#211d1c", bg = "#6b84af" }

[help]
on      = { fg = "#6b84af", bold = true }
run     = { fg = "#c7c6c6" }
desc    = { fg = "#585554" }
hovered = { fg = "#211d1c", bg = "#6b84af" }
footer  = { fg = "#585554" }

[filetype]
# A small set of readable defaults that won't depend on terminal palette.
rules = [
  { mime = "image/*",            fg = "#54729c" },
  { mime = "{audio,video}/*",    fg = "#41567a" },
  { mime = "inode/empty",        fg = "#868abd" },
  { url  = "*", is = "orphan",   fg = "#b98a7d", bold = true },
  { url  = "*/",                fg = "#6b84af", bold = true },
]
