# Auto-generated from pywal by updateYaziTheme.sh
# Source: /home/max/.cache/wal/colors.env
#
# This file intentionally overrides only a handful of high-impact UI styles.
# Anything not specified here falls back to Yazi's preset theme.

[app]
# Requires OSC 11 support (kitty supports it).
overall = { bg = "#201f1f" }

[mgr]
# CWD/header
cwd = { fg = "#cec9a5", bold = true }

# Markers
marker_selected = { fg = "#cec9a5", bold = true }
marker_marked   = { fg = "#587da4", bold = true }
marker_copied   = { fg = "#ac8465", bold = true }
marker_cut      = { fg = "#bc9084", bold = true }

# Counts
count_selected = { fg = "#cec9a5", bold = true }
count_copied   = { fg = "#ac8465" }
count_cut      = { fg = "#bc9084" }

# Pane borders
border_symbol = "│"
border_style  = { fg = "#575757" }

[indicator]
parent  = { fg = "#575757" }
current = { fg = "#cec9a5" }
preview = { fg = "#587da4" }

[tabs]
active   = { fg = "#201f1f", bg = "#cec9a5", bold = true }
inactive = { fg = "#c7c7c7", bg = "#201f1f" }
sep_inner = { open = "[", close = "]" }
sep_outer = { open = "", close = "" }

[mode]
normal_main = { fg = "#201f1f", bg = "#cec9a5", bold = true }
normal_alt  = { fg = "#c7c7c7", bg = "#201f1f" }
select_main = { fg = "#201f1f", bg = "#ac8465", bold = true }
select_alt  = { fg = "#c7c7c7", bg = "#201f1f" }
unset_main  = { fg = "#201f1f", bg = "#bca484", bold = true }
unset_alt   = { fg = "#c7c7c7", bg = "#201f1f" }

[status]
overall         = { fg = "#c7c7c7", bg = "#201f1f" }
progress_label  = { fg = "#cec9a5", bold = true }
progress_normal = { fg = "#201f1f", bg = "#cec9a5" }
progress_error  = { fg = "#201f1f", bg = "#bc9084" }
perm_type  = { fg = "#587da4" }
perm_read  = { fg = "#ac8465" }
perm_write = { fg = "#bca484" }
perm_exec  = { fg = "#bc9084" }
perm_sep   = { fg = "#575757" }

[notify]
title_info  = { fg = "#cec9a5", bold = true }
title_warn  = { fg = "#bca484", bold = true }
title_error = { fg = "#bc9084", bold = true }

[pick]
border   = { fg = "#575757" }
active   = { fg = "#201f1f", bg = "#cec9a5" }
inactive = { fg = "#c7c7c7", bg = "#201f1f" }

[input]
border   = { fg = "#575757" }
title    = { fg = "#cec9a5", bold = true }
value    = { fg = "#c7c7c7" }
selected = { fg = "#201f1f", bg = "#cec9a5" }

[cmp]
border   = { fg = "#575757" }
active   = { fg = "#201f1f", bg = "#cec9a5" }
inactive = { fg = "#c7c7c7", bg = "#201f1f" }

[tasks]
border  = { fg = "#575757" }
title   = { fg = "#cec9a5", bold = true }
hovered = { fg = "#201f1f", bg = "#cec9a5" }

[help]
on      = { fg = "#cec9a5", bold = true }
run     = { fg = "#c7c7c7" }
desc    = { fg = "#575757" }
hovered = { fg = "#201f1f", bg = "#cec9a5" }
footer  = { fg = "#575757" }

[filetype]
# A small set of readable defaults that won't depend on terminal palette.
rules = [
  { mime = "image/*",            fg = "#bca484" },
  { mime = "{audio,video}/*",    fg = "#6f92b2" },
  { mime = "inode/empty",        fg = "#587da4" },
  { url  = "*", is = "orphan",   fg = "#bc9084", bold = true },
  { url  = "*/",                fg = "#cec9a5", bold = true },
]
